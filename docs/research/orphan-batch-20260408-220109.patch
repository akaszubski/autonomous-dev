+class TestBatchCrossIssueOrderingFalsePositive:
+    """Regression tests for Issue #732: cross-issue ordering false positives in batch mode.
+
+    In a batch session mixing --fix (implementer-only) and --light (planner + implementer)
+    issues, the step_ordering check must not flag a CRITICAL violation when the --fix
+    implementer ran before a different issue's planner.
+    """
+
+    def _make_event(
+        self,
+        subagent_type: str,
+        timestamp: str,
+        *,
+        batch_issue_number: int = 0,
+    ) -> "PipelineEvent":
+        """Create a PipelineEvent directly for ordering tests."""
+        return PipelineEvent(
+            timestamp=timestamp,
+            tool="Task",
+            agent="main",
+            subagent_type=subagent_type,
+            pipeline_action="agent_invocation",
+            batch_issue_number=batch_issue_number,
+        )
+
+    def test_fix_implementer_before_light_planner_no_false_positive(self):
+        """No ordering violation when --fix implementer ran before --light planner.
+
+        Scenario:
+        - Issue #100 (--fix): implementer at T=10:00 (no planner expected in --fix mode)
+        - Issue #200 (--light): planner at T=10:05, implementer at T=10:10
+
+        Both issues have tagged batch_issue_numbers. The --fix issue is implementer-only
+        (valid for --fix mode). The ordering check must NOT produce a cross-issue
+        false positive saying "implementer before planner". (#732)
+        """
+        events = [
+            self._make_event("implementer", "2026-04-01T10:00:00Z", batch_issue_number=100),
+            self._make_event("planner", "2026-04-01T10:05:00Z", batch_issue_number=200),
+            self._make_event("implementer", "2026-04-01T10:10:00Z", batch_issue_number=200),
+        ]
+
+        findings = validate_step_ordering(events)
+
+        ordering_violations = [f for f in findings if f.finding_type == "step_ordering"]
+        assert len(ordering_violations) == 0, (
+            f"#732: False positive: fix implementer before light planner should not be flagged. "
+            f"Got: {[(f.pattern_id, f.description) for f in ordering_violations]}"
+        )
+
+    def test_untagged_fix_implementer_before_untagged_light_planner_no_false_positive(
+        self, tmp_path: Path
+    ):
+        """No ordering violation when --fix and --light events both lack issue number tags.
+
+        Scenario (batch session, both events have batch_issue_number=0):
+        - --fix implementer at T=10:00 (batch_issue_number=0, prompt didn't match 'Issue #N')
+        - --light planner at T=10:05 (batch_issue_number=0)
+        - --light implementer at T=10:10 (batch_issue_number=0)
+
+        When SOME events in the session have batch_issue_numbers > 0 (from other issues),
+        untagged events (group 0) must be excluded from ordering checks to prevent
+        cross-issue false positives. (#732)
+        """
+        # One tagged event makes this a batch session
+        tagged_event = self._make_event(
+            "researcher", "2026-04-01T09:55:00Z", batch_issue_number=300
+        )
+        # Untagged --fix implementer ran first
+        fix_implementer = self._make_event("implementer", "2026-04-01T10:00:00Z")
+        # Untagged --light planner ran after
+        light_planner = self._make_event("planner", "2026-04-01T10:05:00Z")
+        # Untagged --light implementer ran after planner
+        light_implementer = self._make_event("implementer", "2026-04-01T10:10:00Z")
+
+        events = [tagged_event, fix_implementer, light_planner, light_implementer]
+
+        findings = validate_step_ordering(events)
+
+        ordering_violations = [f for f in findings if f.finding_type == "step_ordering"]
+        assert len(ordering_violations) == 0, (
+            f"#732: False positive: untagged events in batch mode (group 0) should be skipped. "
+            f"Got: {[(f.pattern_id, f.description) for f in ordering_violations]}"
+        )
+
+    def test_genuine_ordering_violation_within_same_issue_still_detected(self):
+        """A real ordering violation within a single issue is still detected.
+
+        If implementer ran before planner FOR THE SAME issue (same batch_issue_number),
+        this IS a real violation and must still be reported. The fix must not suppress
+        legitimate findings.
+        """
+        events = [
+            # Issue 500: implementer ran before planner (genuine violation)
+            self._make_event("implementer", "2026-04-01T10:00:00Z", batch_issue_number=500),
+            self._make_event("planner", "2026-04-01T10:05:00Z", batch_issue_number=500),
+        ]
+
+        findings = validate_step_ordering(events)
+
+        ordering_violations = [f for f in findings if f.finding_type == "step_ordering"]
+        assert len(ordering_violations) == 1, (
+            f"#732: Genuine same-issue ordering violation must still be detected. "
+            f"Got {len(ordering_violations)} findings: "
+            f"{[(f.pattern_id, f.description) for f in ordering_violations]}"
+        )
+        assert "implementer" in ordering_violations[0].description
+        assert "planner" in ordering_violations[0].description
+
+    def test_non_batch_mode_ordering_still_checked_globally(self):
+        """In non-batch mode (no tagged events), global ordering check still applies.
+
+        When ALL events have batch_issue_number=0 and there are no tagged batch events,
+        this is treated as a non-batch session and global ordering is checked normally.
+        """
+        events = [
+            # All untagged — non-batch session with genuine ordering violation
+            self._make_event("implementer", "2026-04-01T10:00:00Z"),
+            self._make_event("planner", "2026-04-01T10:05:00Z"),
+        ]
+
+        findings = validate_step_ordering(events)
+
+        ordering_violations = [f for f in findings if f.finding_type == "step_ordering"]
+        assert len(ordering_violations) == 1, (
+            f"Non-batch mode: implementer before planner (same session) must be flagged. "
+            f"Got {len(ordering_violations)} findings."
+        )
