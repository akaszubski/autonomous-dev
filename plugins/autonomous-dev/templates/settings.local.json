{
  "_comment": "Hooks live exclusively in settings.json (managed by sync_settings_hooks.py). This file carries permissions and user customizations only. Registering hooks here causes double-fires (Issue #1183, follow-up to #1176).",
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Bash",
      "Task",
      "TaskOutput",
      "TaskCreate",
      "TaskUpdate",
      "TaskList",
      "TaskGet",
      "TaskStop",
      "WebFetch",
      "WebSearch",
      "TodoWrite",
      "NotebookEdit",
      "Agent",
      "AgentOutputTool",
      "AskUserQuestion",
      "EnterPlanMode",
      "ExitPlanMode",
      "EnterWorktree",
      "ToolSearch",
      "Skill",
      "SlashCommand",
      "BashOutput",
      "KillShell",
      "LSP",
      "mcp__*"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gh/**)",
      "Write(/etc/**)",
      "Write(/System/**)",
      "Write(/usr/**)",
      "Write(~/.ssh/**)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(sudo:*)",
      "Bash(chmod 777:*)",
      "Bash(curl*|*bash)",
      "Bash(wget*|*bash)"
    ]
  },
  "hooks": {}
}
